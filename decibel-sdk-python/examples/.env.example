# Decibel API credentials
# Get these from https://app.decibel.trade/api and https://geomi.dev

# Bearer token from Geomi (required for all examples)
BEARER_TOKEN=your_bearer_token_here

# Ed25519 private key hex from Decibel API Wallet (required for trading examples)
PRIVATE_KEY=0xyour_private_key_here

# Your trading account (subaccount) address
# Created automatically when you first use the Decibel App
SUBACCOUNT_ADDRESS=0xyour_subaccount_address_here

# Aptos node API key from Geomi (optional, for higher rate limits)
NODE_API_KEY=
